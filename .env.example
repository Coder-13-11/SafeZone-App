PORT=4173
NODE_ENV=production
DATA_FILE=./data/safezone.json
# Public HTTPS origin used inside patient-device pairing QR codes.
PUBLIC_URL=https://safezone.example.com

# Generate once with: npm run vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Default geofence confirmation window.
GRACE_PERIOD_MS=10000

# Vercel frontend Supabase mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PUBLIC_URL=https://safezone.example.com
VITE_VAPID_PUBLIC_KEY=

# Supabase Edge Function secrets.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VAPID_KEYS_FILE=./data/vapid-keys.json
